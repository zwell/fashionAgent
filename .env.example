# LLM — OpenAI 官方，或 DeepSeek / 通义千问（DashScope OpenAI 兼容模式）
# LLM_PROVIDER=openai   # 默认；填 deepseek | qwen | custom
# OPENAI_API_BASE=      # custom 时必填；也可覆盖预设 base
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
#
# DeepSeek 示例:
#   LLM_PROVIDER=deepseek
#   OPENAI_API_KEY=<deepseek-api-key>
#   OPENAI_MODEL=deepseek-chat
#
# 通义千问（兼容模式）示例:
#   LLM_PROVIDER=qwen
#   OPENAI_API_KEY=<dashscope-api-key>
#   OPENAI_MODEL=qwen-plus

# Redis
REDIS_URL=redis://localhost:6379/0

# Milvus (Phase 3)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Neo4j (Phase 3)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# LangSmith
LANGSMITH_API_KEY=ls-xxx
LANGSMITH_PROJECT=fashion-agent
LANGCHAIN_TRACING_V2=true

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
