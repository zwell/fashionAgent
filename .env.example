# LLM — OpenAI 官方，或 DeepSeek / 通义千问（DashScope OpenAI 兼容模式）
# LLM_PROVIDER=openai   # 默认；填 deepseek | qwen | custom
# OPENAI_API_BASE=      # custom 时必填；也可覆盖预设 base
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
#
# DeepSeek 示例:
#   LLM_PROVIDER=deepseek
#   OPENAI_API_KEY=<deepseek-api-key>
#   OPENAI_MODEL=deepseek-chat
#
# 通义千问（兼容模式）示例:
#   LLM_PROVIDER=qwen
#   OPENAI_API_KEY=<dashscope-api-key>
#   OPENAI_MODEL=qwen-plus

# Redis
REDIS_URL=redis://localhost:6379/0

# Milvus (Phase 3)
# /healthz 在 9091；Python SDK 走 19530 的 gRPC，两端口都通才算连上。
MILVUS_HOST=localhost
MILVUS_PORT=19530
# MILVUS_URI=http://127.0.0.1:19530
# MILVUS_CONNECT_TIMEOUT=45
# MILVUS_EXTEND_NO_PROXY=true
# Windows 若仍超时：确认 ``pip show grpcio`` 版本 < 1.68；可设 GRPC_POLL_STRATEGY=poll
# 服务端 milvus:v2.5.x 时建议: pip install "pymilvus>=2.5.4,<2.6" 且让项目约束的 grpcio 生效

# Neo4j (Phase 3)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# LangSmith
LANGSMITH_API_KEY=ls-xxx
LANGSMITH_PROJECT=fashion-agent
LANGCHAIN_TRACING_V2=true

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
